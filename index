    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #E8957A;
    margin-bottom: 24px;
    font-weight: 500;
  }

  .money-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    margin-bottom: 28px;
  }

  .money-block .stat {
    font-size: 38px;
    font-weight: normal;
    color: #F5F0EC;
    line-height: 1.1;
    margin-bottom: 4px;
  }

  .money-block .stat-label {
    font-family: 'Helvetica Neue', sans-serif;
    font-size: 12px;
    color: #7A748A;
    line-height: 1.5;
  }

  .money-block p {
    font-size: 15px;
    color: #B8B2CC;
    max-width: none;
    margin-bottom: 0;
    line-height: 1.75;
  }

  .scale-block {
    background: #F0EBF8;
    border-radius: 16px;
    padding: 36px;
    margin: 28px 0;
  }

  .scale-block p { color: #3A2E50; max-width: none; }

  .moon {
    background: #2A1F3D;
    border-radius: 16px;
    padding: 48px 40px;
    margin: 28px 0;
  }

  .moon h3 {
    font-family: 'Helvetica Neue', sans-serif;
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #F2C94C;
    margin-bottom: 28px;
    font-weight: 500;
  }

  .moon-item {
    display: flex;
    gap: 16px;
    margin-bottom: 22px;
    align-items: flex-start;
  }

  .moon-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #F2C94C;
    margin-top: 10px;
    flex-shrink: 0;
    opacity: 0.7;
  }

  .moon-item p {
    margin: 0;
    font-size: 15px;
    color: #C4BAD8;
    max-width: none;
    line-height: 1.75;
  }

  .closing {
    background: #1C1A2E;
    text-align: center;
    padding: 72px 40px 80px;
  }

  .closing p {
    font-size: 19px;
    font-style: italic;
    color: #A9A4C0;
    margin: 0 auto 28px;
    max-width: 500px;
    line-height: 1.75;
  }

  .closing .name {
    font-family: 'Helvetica Neue', sans-serif;
    font-size: 12px;
    letter-spacing: 0.1em;
