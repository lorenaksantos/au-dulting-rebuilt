    color: #E8957A;
    font-style: normal;
  }

  @media (max-width: 600px) {
    .hero { padding: 56px 24px 56px; }
    section { padding-left: 24px; padding-right: 24px; }
    .money-block, .moon, .scale-block { padding: 28px 20px; }
    .money-stats { grid-template-columns: 1fr; gap: 16px; }
    .closing { padding: 56px 24px 64px; }
  }
