  h1 {
    font-size: clamp(38px, 6vw, 58px);
    font-weight: normal;
    line-height: 1.12;
    color: #F5F0EC;
    margin-bottom: 28px;
  }

  h1 em {
    font-style: italic;
    color: #E8957A;
  }

  .hero-sub {
    font-size: 18px;
    color: #A9A4C0;
    max-width: 540px;
    line-height: 1.8;
    font-family: 'Helvetica Neue', sans-serif;
    font-weight: 300;
  }

  .divider {
    width: 40px;
    height: 2px;
    background: #E8957A;
    margin: 56px auto;
    opacity: 0.5;
  }

  section {
    max-width: 720px;
    margin: 0 auto;
    padding: 0 40px 56px;
  }

  h2 {
    font-size: 11px;
    font-family: 'Helvetica Neue', sans-serif;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #C4748A;
    margin-bottom: 20px;
    font-weight: 500;
  }

  p {
    font-size: 17px;
    color: #2E2A40;
    margin-bottom: 18px;
    max-width: 640px;
  }

  .pull-quote {
    border-left: 3px solid #E8957A;
    padding: 4px 0 4px 24px;
    margin: 36px 0;
    font-size: 20px;
    font-style: italic;
    color: #3A2E50;
    line-height: 1.65;
  }

  .joy-cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 12px;
    margin: 28px 0;
  }

  .joy-card {
    background: #fff;
    border: 1px solid #EAE4F0;
    border-radius: 12px;
    padding: 20px 16px;
    text-align: center;
  }

  .joy-card .icon {
    font-size: 28px;
    margin-bottom: 10px;
    display: block;
  }

  .joy-card p {
    font-family: 'Helvetica Neue', sans-serif;
    font-size: 13px;
    color: #5A5470;
    margin: 0;
    line-height: 1.5;
    max-width: none;
  }

  .cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 14px;
    margin: 28px 0;
  }

  .card {
    background: #fff;
    border: 1px solid #EAE4F0;
    border-radius: 12px;
    padding: 20px;
  }

  .card-icon { font-size: 22px; margin-bottom: 10px; }

  .card h3 {
    font-family: 'Helvetica Neue', sans-serif;
    font-size: 13px;
    font-weight: 600;
    color: #1C1A2E;
    margin-bottom: 6px;
  }

  .card p {
    font-size: 14px;
    color: #6B647A;
    margin: 0;
    line-height: 1.6;
    max-width: none;
  }

  .money-block {
    background: #1C1A2E;
    border-radius: 16px;
    padding: 40px;
    margin: 28px 0;
  }

  .money-block h3 {
    font-family: 'Helvetica Neue', sans-serif;
